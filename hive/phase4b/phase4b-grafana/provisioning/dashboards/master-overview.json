{
  "title": "Hive — Master Overview",
  "uid": "hive-master",
  "tags": ["hive", "master"],
  "timezone": "utc",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "schemaVersion": 38,
  "version": 1,

  "templating": {
    "list": [
      {
        "name": "surface",
        "label": "Surface",
        "type": "custom",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": { "text": "All", "value": "*" },
        "options": [
          { "selected": true, "text": "All",  "value": "*"   },
          { "selected": false, "text": "Web",  "value": "web" },
          { "selected": false, "text": "SSH",  "value": "ssh" },
          { "selected": false, "text": "IDS",  "value": "ids" }
        ]
      },
      {
        "name": "interval",
        "label": "Bucket",
        "type": "interval",
        "hide": 0,
        "auto": false,
        "current": { "text": "1h", "value": "1h" },
        "options": [
          { "selected": false, "text": "15m", "value": "15m" },
          { "selected": false, "text": "30m", "value": "30m" },
          { "selected": true,  "text": "1h",  "value": "1h"  },
          { "selected": false, "text": "6h",  "value": "6h"  },
          { "selected": false, "text": "1d",  "value": "1d"  }
        ]
      }
    ]
  },

  "panels": [

    {
      "id": 100, "type": "row", "title": "Overview",
      "collapsed": false, "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1, "title": "Total Events",
      "type": "stat", "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-all" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [], "query": "honeypot_surface:$surface", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 2, "title": "Unique Source IPs",
      "type": "stat", "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-all" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "cardinality", "id": "1", "field": "src_ip" }],
        "bucketAggs": [], "query": "honeypot_surface:$surface", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "id": 3, "title": "Web Hits",
      "type": "stat", "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-web" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [], "query": "", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "green", "mode": "fixed" } } }
    },
    {
      "id": 4, "title": "SSH Attempts",
      "type": "stat", "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [], "query": "cowrie_event_type:cowrie.login.*", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 5, "title": "IDS Alerts",
      "type": "stat", "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [], "query": "event_type:alert", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "purple", "mode": "fixed" } } }
    },
    {
      "id": 6, "title": "/.env Hits",
      "type": "stat", "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-web" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [], "query": "path:\\.env", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "orange", "value": 3 }, { "color": "red", "value": 10 }
        ]}
      }}
    },
    {
      "id": 7, "title": "Events per $interval by Surface",
      "type": "timeseries", "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-all" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "honeypot_surface", "id": "3",
            "settings": { "size": "5", "order": "desc", "orderBy": "1", "min_doc_count": "1" } },
          { "type": "date_histogram", "field": "@timestamp", "id": "2",
            "settings": { "interval": "$interval", "min_doc_count": "0" } }
        ],
        "query": "honeypot_surface:$surface", "timeField": "@timestamp"
      }],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } } }
    },
    {
      "id": 8, "title": "Events by Surface",
      "type": "piechart", "gridPos": { "x": 16, "y": 5, "w": 8, "h": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-all" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "honeypot_surface", "id": "2",
            "settings": { "size": "10", "order": "desc", "orderBy": "1" } }
        ],
        "query": "honeypot_surface:$surface", "timeField": "@timestamp"
      }],
      "options": { "pieType": "donut", "tooltip": { "mode": "single" } }
    },

    {
      "id": 200, "type": "row", "title": "Web Hive",
      "collapsed": false, "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },
    {
      "id": 9, "title": "Top 20 Requested Paths",
      "type": "bargauge", "gridPos": { "x": 0, "y": 14, "w": 12, "h": 10 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-web" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "path", "id": "2",
            "settings": { "size": "20", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "lcd" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 15 }
        ]}
      }}
    },
    {
      "id": 10, "title": "Top User Agents (Scanner Detection)",
      "type": "bargauge", "gridPos": { "x": 12, "y": 14, "w": 12, "h": 10 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-web" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "user_agent.keyword", "id": "2",
            "settings": { "size": "15", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 11, "title": "Recent Web Requests",
      "type": "table", "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-web" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "logs", "id": "1" }],
        "bucketAggs": [], "query": "", "timeField": "@timestamp"
      }],
      "options": { "sortBy": [{ "displayName": "Time", "desc": true }] },
      "transformations": [{ "id": "organize", "options": {
        "excludeByName": { "_id": true, "_index": true, "_type": true, "headers": true, "post_body": true, "honeypot_surface": true, "log_source": true, "query_string": true },
        "renameByName": { "@timestamp": "Time", "remote_ip": "Source IP", "method": "Method", "path": "Path", "user_agent": "User Agent", "response_code": "Status" }
      }}]
    },

    {
      "id": 300, "type": "row", "title": "SSH / Cowrie",
      "collapsed": false, "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 }
    },
    {
      "id": 12, "title": "Login Attempts per $interval",
      "type": "timeseries", "gridPos": { "x": 0, "y": 33, "w": 16, "h": 7 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [
        { "refId": "A", "alias": "Failed",
          "metrics": [{ "type": "count", "id": "1" }],
          "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2",
            "settings": { "interval": "$interval", "min_doc_count": "0" } }],
          "query": "cowrie_event_type:cowrie.login.failed", "timeField": "@timestamp"
        },
        { "refId": "B", "alias": "Success",
          "metrics": [{ "type": "count", "id": "1" }],
          "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2",
            "settings": { "interval": "$interval", "min_doc_count": "0" } }],
          "query": "cowrie_event_type:cowrie.login.success", "timeField": "@timestamp"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 13, "title": "Sessions",
      "type": "stat", "gridPos": { "x": 16, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "cardinality", "id": "1", "field": "session" }],
        "bucketAggs": [], "query": "", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 14, "title": "Successful Logins",
      "type": "stat", "gridPos": { "x": 20, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [], "query": "cowrie_event_type:cowrie.login.success", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "red", "value": 1 }
        ]}
      }}
    },
    {
      "id": 15, "title": "Command Sessions",
      "type": "stat", "gridPos": { "x": 16, "y": 37, "w": 8, "h": 3 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "cardinality", "id": "1", "field": "session" }],
        "bucketAggs": [], "query": "cowrie_event_type:cowrie.command.input", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "yellow", "mode": "fixed" } } }
    },
    {
      "id": 16, "title": "Top Credential Pairs",
      "type": "table", "gridPos": { "x": 0, "y": 40, "w": 10, "h": 10 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "username", "id": "2",
            "settings": { "size": "20", "order": "desc", "orderBy": "1", "min_doc_count": "1" } },
          { "type": "terms", "field": "password", "id": "3",
            "settings": { "size": "5", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "cowrie_event_type:cowrie.login.*", "timeField": "@timestamp"
      }],
      "options": { "sortBy": [{ "displayName": "Count", "desc": true }] }
    },
    {
      "id": 17, "title": "Top Usernames",
      "type": "bargauge", "gridPos": { "x": 10, "y": 40, "w": 7, "h": 10 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "username", "id": "2",
            "settings": { "size": "15", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "cowrie_event_type:cowrie.login.*", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 18, "title": "Top Passwords",
      "type": "bargauge", "gridPos": { "x": 17, "y": 40, "w": 7, "h": 10 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "password", "id": "2",
            "settings": { "size": "15", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "cowrie_event_type:cowrie.login.*", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "id": 19, "title": "Top Commands Executed",
      "type": "table", "gridPos": { "x": 0, "y": 50, "w": 12, "h": 7 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "input", "id": "2",
            "settings": { "size": "20", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "cowrie_event_type:cowrie.command.input", "timeField": "@timestamp"
      }]
    },
    {
      "id": 20, "title": "Files Attempted to Download",
      "type": "table", "gridPos": { "x": 12, "y": 50, "w": 12, "h": 7 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-cowrie" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "url", "id": "2",
            "settings": { "size": "20", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "cowrie_event_type:cowrie.session.file_download*", "timeField": "@timestamp"
      }]
    },

    {
      "id": 400, "type": "row", "title": "IDS Alerts (Suricata)",
      "collapsed": false, "gridPos": { "x": 0, "y": 57, "w": 24, "h": 1 }
    },
    {
      "id": 21, "title": "Total Alerts",
      "type": "stat", "gridPos": { "x": 0, "y": 58, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [], "query": "event_type:alert", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }
        ]}
      }}
    },
    {
      "id": 22, "title": "Unique Attacker IPs",
      "type": "stat", "gridPos": { "x": 4, "y": 58, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "cardinality", "id": "1", "field": "src_ip" }],
        "bucketAggs": [], "query": "event_type:alert", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "id": 23, "title": "Unique SSH Fingerprints",
      "type": "stat", "gridPos": { "x": 8, "y": 58, "w": 4, "h": 4 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "cardinality", "id": "1", "field": "ssh.hassh.hash" }],
        "bucketAggs": [], "query": "event_type:ssh", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "purple", "mode": "fixed" } } }
    },
    {
      "id": 24, "title": "Alert Events per $interval",
      "type": "timeseries", "gridPos": { "x": 0, "y": 62, "w": 24, "h": 7 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [{ "type": "date_histogram", "field": "@timestamp", "id": "2",
          "settings": { "interval": "$interval", "min_doc_count": "0" } }],
        "query": "event_type:alert", "timeField": "@timestamp"
      }],
      "options": { "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 },
        "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 25, "title": "Top Alert Signatures",
      "type": "bargauge", "gridPos": { "x": 0, "y": 69, "w": 14, "h": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "alert.signature", "id": "2",
            "settings": { "size": "10", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "event_type:alert", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "lcd" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 26, "title": "Top Destination Ports",
      "type": "bargauge", "gridPos": { "x": 14, "y": 69, "w": 10, "h": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "count", "id": "1" }],
        "bucketAggs": [
          { "type": "terms", "field": "dest_port", "id": "2",
            "settings": { "size": "10", "order": "desc", "orderBy": "1", "min_doc_count": "1" } }
        ],
        "query": "", "timeField": "@timestamp"
      }],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 27, "title": "Recent Alerts",
      "type": "table", "gridPos": { "x": 0, "y": 77, "w": 24, "h": 8 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch-suricata" },
      "targets": [{ "refId": "A",
        "metrics": [{ "type": "logs", "id": "1" }],
        "bucketAggs": [], "query": "event_type:alert", "timeField": "@timestamp"
      }],
      "options": { "sortBy": [{ "displayName": "Time", "desc": true }] },
      "transformations": [{ "id": "organize", "options": {
        "excludeByName": { "_id": true, "_index": true, "_type": true, "honeypot_surface": true, "log_source": true, "proto": true },
        "renameByName": { "@timestamp": "Time", "src_ip": "Source IP", "dest_ip": "Dest IP", "dest_port": "Port", "alert.signature": "Signature", "alert.severity": "Severity" }
      }}]
    },

    {
      "id": 500, "type": "row", "title": "Geographic Distribution",
      "collapsed": false, "gridPos": { "x": 0, "y": 85, "w": 24, "h": 1 }
    },
    {
